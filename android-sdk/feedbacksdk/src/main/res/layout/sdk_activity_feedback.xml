<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        style="@style/Widget.FeedbackSDK.AppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.FeedbackSDK.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/sdk_ic_back"
            app:navigationContentDescription="@string/sdk_back"
            app:title="@string/sdk_submit_feedback" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.FeedbackSDK.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sdk_rate_experience"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvRatingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sdk_tap_to_rate"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/starsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/star1"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="6dp"
                            android:src="@drawable/sdk_ic_star_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="1 star" />

                        <ImageView
                            android:id="@+id/star2"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="6dp"
                            android:src="@drawable/sdk_ic_star_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="2 stars" />

                        <ImageView
                            android:id="@+id/star3"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="6dp"
                            android:src="@drawable/sdk_ic_star_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="3 stars" />

                        <ImageView
                            android:id="@+id/star4"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="6dp"
                            android:src="@drawable/sdk_ic_star_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="4 stars" />

                        <ImageView
                            android:id="@+id/star5"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:padding="6dp"
                            android:src="@drawable/sdk_ic_star_outline"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="5 stars" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sdk_category"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGeneral"
                    style="@style/Widget.FeedbackSDK.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="General" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBug"
                    style="@style/Widget.FeedbackSDK.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bug Report" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFeature"
                    style="@style/Widget.FeedbackSDK.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feature Request" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSuggestion"
                    style="@style/Widget.FeedbackSDK.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suggestion" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipComplaint"
                    style="@style/Widget.FeedbackSDK.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complaint" />
            </com.google.android.material.chip.ChipGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FeedbackSDK.TextField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="@string/sdk_comment_optional">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="3"
                    android:gravity="top|start" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sdk_attachments"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAttachments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                tools:itemCount="2"
                tools:listitem="@layout/sdk_item_pending_attachment"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAttach"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sdk_add_attachment"
                app:icon="@drawable/sdk_ic_add"
                app:iconGravity="textStart" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            style="@style/Widget.FeedbackSDK.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sdk_submit" />
    </LinearLayout>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
