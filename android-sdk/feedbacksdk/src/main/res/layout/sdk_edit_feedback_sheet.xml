<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/sdk_ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="1 star" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/sdk_ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="2 stars" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/sdk_ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="3 stars" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/sdk_ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="4 stars" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/sdk_ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="5 stars" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FeedbackSDK.TextField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/sdk_comment_optional">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="3"
            android:gravity="top|start" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
