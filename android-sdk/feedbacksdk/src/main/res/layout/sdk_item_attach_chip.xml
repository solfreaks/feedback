<?xml version="1.0" encoding="utf-8"?>
<!--
  Single pending-attachment chip shown in the reply composer. User selects
  files before sending; each gets rendered as one of these rows with a
  tappable × to remove. No persistence — purely pre-send state.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="6dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="4dp"
    android:paddingVertical="4dp"
    android:background="@drawable/sdk_bg_badge">

    <TextView
        android:id="@+id/tvChipName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="160dp"
        android:ellipsize="middle"
        android:singleLine="true"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurface" />

    <ImageView
        android:id="@+id/btnChipRemove"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="4dp"
        android:padding="2dp"
        android:src="@drawable/sdk_ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/sdk_cancel"
        app:tint="?attr/colorOnSurfaceVariant" />
</LinearLayout>
