<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.FeedbackSDK.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextAppearance">@style/TextAppearance.Material3.TitleLarge</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
    </style>

    <style name="Widget.FeedbackSDK.AppBar" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">?attr/colorSurface</item>
        <item name="elevation">0dp</item>
        <item name="liftOnScroll">true</item>
    </style>

    <style name="Widget.FeedbackSDK.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="rippleColor">?attr/colorPrimary</item>
    </style>

    <style name="Widget.FeedbackSDK.TextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.FeedbackSDK.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FeedbackSDK.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">12dp</item>
    </style>

    <style name="TextAppearance.FeedbackSDK.Badge" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textSize">11sp</item>
    </style>
</resources>
